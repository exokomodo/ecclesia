#!/usr/bin/env bash
# Pre-commit hook — runs make check before every commit.
# Install: make setup/hooks
set -euo pipefail

# Prefer gmake (GNU make) when available — required on macOS where the
# system make is BSD make and incompatible with this Makefile.
if command -v gmake &>/dev/null; then
  MAKE=gmake
else
  MAKE=make
fi

echo "Running build across supported architectures..."
for arch in x86_64; do
  echo "  - $arch"
  export TARGET_ARCH="${arch}"
  if ! "${MAKE}" build; then
    echo ""
    echo "❌ Build failed for ${arch}. Fix the issues above before committing."
    exit 1
  fi

  if ! "${MAKE}" test/unit; then
    echo ""
    echo "❌ Unit tests failed for ${arch}. Fix the issues above before committing."
    exit 1
  fi
done
unset TARGET_ARCH
